# ============================================================
# PLANTILLA DE VARIABLES DE ENTORNO - IMC Nutricion Backend
# Copia este archivo como .env y rellena los valores.
# NUNCA subas el archivo .env al repositorio de código.
# ============================================================

# JWT Secret: mínimo 64 caracteres aleatorios (512 bits de entropía)
# Generar con: openssl rand -hex 64
JWT_SECRET=REEMPLAZA_CON_64_BYTES_ALEATORIOS_HEX

# Duración del token JWT en milisegundos (86400000 = 24 horas)
JWT_EXPIRATION_MS=86400000

# Credenciales del administrador inicial
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=REEMPLAZA_CON_CONTRASENA_SEGURA

# Base de datos (producción)
DB_URL=jdbc:postgresql://localhost:5432/nutricion_db
DB_USERNAME=nutricion_user
DB_PASSWORD=REEMPLAZA_CON_CONTRASENA_BD

# TLS/SSL (producción)
SSL_KEYSTORE_PATH=classpath:keystore/nutricion.p12
SSL_KEYSTORE_PASSWORD=REEMPLAZA_CON_CONTRASENA_KEYSTORE
SSL_KEY_ALIAS=nutricion-tls
